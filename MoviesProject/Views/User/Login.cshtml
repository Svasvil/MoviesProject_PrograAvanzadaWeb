<form asp-action="Login" method="post">
    <div class="mb-3 text-start">
        <label class="form-label">Terminal ID (Email):</label>
        <input type="email" name="email" class="form-control retro-input" placeholder="ADMIN@RETRO.COM" required />
    </div>

    <div class="mb-3 text-start">
        <label class="form-label">Access Code (Password):</label>
        <input type="password" name="password" class="form-control retro-input" placeholder="********" required />
    </div>

    <button type="submit" class="btn btn-retro">EXECUTE LOGIN</button>
</form>